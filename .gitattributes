# Auto detect text files and perform LF normalization
* text=auto

# Python source files
*.py text eol=lf
*.pyw text eol=lf

# Shell scripts
*.sh text eol=lf

# Batch scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# JSON, YAML, Markdown
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Requirements
requirements*.txt text eol=lf
